{
  "name": "deadlibrary-cli",
  "version": "0.2.3",
  "description": "Deterministic Angular and Angular Material code generation CLI.",
  "main": "./dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
